    {
      "id": "enrich-parserows",
      "name": "Parse Rows To Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [912, 304],
      "parameters": {
        "jsCode": "const globalStore = $getWorkflowStaticData('global');\nconst STALE_MS = 15 * 60 * 1000;\nconst lock = globalStore._enriching;\nif (lock && (Date.now() - lock.startedAt) < STALE_MS) {\n  return [{ json: { already_running: true, total: 0, leads: [] } }];\n}\n\nconst sheet1Raw = $('Read Sheet Rows').first().json;\nconst [headers, ...rows] = sheet1Raw.values || [[]];\n\nconst dmRaw = $input.first().json;\nconst dmAllRows = (dmRaw.error || !dmRaw.values) ? [] : (dmRaw.values || []);\nconst enrichedPlaceIds = new Set();\ndmAllRows.forEach((row, i) => {\n  if (i === 0) return;\n  const placeId = (row && row[0]) || '';\n  if (placeId) enrichedPlaceIds.add(placeId);\n});\n\nconst onlyMissing = $('Webhook').first().json.body?.only_missing !== false;\nconst leads = rows\n  .map((row, i) => ({\n    ...Object.fromEntries(headers.map((h, j) => [h, row[j] || ''])),\n    _rowNumber: i + 2\n  }))\n  .filter(lead => !onlyMissing || !enrichedPlaceIds.has(lead.place_id));\n\nif (leads.length === 0) {\n  return [{ json: { already_running: false, total: 0, leads: [] } }];\n}\n\nglobalStore._enriching = { executionId: $execution.id, startedAt: Date.now() };\nreturn [{ json: { already_running: false, total: leads.length, leads } }];"
      }
    },
