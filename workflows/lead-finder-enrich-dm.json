    {
      "id": "parse-dm-sheet",
      "name": "Parse DM Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [688, 600],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst allRows = (raw.error || !raw.values) ? [] : (raw.values || []);\nconst dm = {};\nallRows.forEach((row, i) => {\n  if (i === 0) return;\n  const placeId = (row && row[0]) || '';\n  if (placeId) {\n    dm[placeId] = {\n      person_name:      (row[2] || ''),\n      person_title:     (row[3] || ''),\n      person_phone:     (row[4] || ''),\n      person_email:     (row[5] || ''),\n      person_linkedin:  (row[6] || ''),\n      person_instagram: (row[7] || ''),\n      person_twitter:   (row[8] || '')\n    };\n  }\n});\nreturn [{ json: { dm } }];"
      }
    },
