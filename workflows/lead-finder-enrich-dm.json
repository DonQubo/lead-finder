    {
      "id": "enrich-buildllmbody",
      "name": "Build LLM Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2896, 304],
      "parameters": {
        "jsCode": "const execId = $execution.id;\nconst store = $getWorkflowStaticData('global');\nconst leadInfo = store[execId]?.leadInfo || {};\nconst broadResult = store[execId]?.broadResults || {};\nconst siteResult = $input.first().json;\nfunction extractContext(result) {\n  const answer = (result.answer || '').substring(0, 400);\n  const results = (result.results || []).slice(0, 3).map(r => r.title + '\\n' + r.url + '\\n' + (r.content || '').substring(0, 300)).join('\\n---\\n');\n  return [answer, results].filter(Boolean).join('\\n\\n');\n}\nconst broadContext = extractContext(broadResult);\nconst siteContext = extractContext(siteResult);\nconst contextBlock = [broadContext, siteContext ? '=== Targeted Search ===\\n' + siteContext : ''].filter(Boolean).join('\\n\\n');\nconst prompt = 'Business: ' + (leadInfo.name || 'N/A') + ', ' + (leadInfo.address || 'N/A') + '\\nWebsite: ' + (leadInfo.website || 'N/A') + '\\n\\nSearch results:\\n' + (contextBlock || 'No results') + '\\n\\nExtract the decision maker (owner, CEO, Director) using ONLY the results above. Return N/A for any field not supported by results.\\n\\nFormat:\\nPERSON_NAME: [name or N/A]\\nPERSON_TITLE: [title or N/A]\\nPERSON_PHONE: [direct phone or N/A]\\nPERSON_EMAIL: [email or N/A]\\nPERSON_LINKEDIN: [URL or N/A]\\nPERSON_INSTAGRAM: [URL or N/A]\\nPERSON_TWITTER: [URL or N/A]';\nreturn [{ json: { llm_body: { model: 'gpt-4o-mini', max_tokens: 300, temperature: 0.1, messages: [{ role: 'user', content: prompt }] }}}];"
      }
    },
    {
      "id": "enrich-callllm",
      "name": "Call LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [3104, 304],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" }
          ]
