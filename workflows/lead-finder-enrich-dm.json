    {
      "id": "enrich-parsedm",
      "name": "Parse DM Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3328, 304],
      "parameters": {
        "jsCode": "const execId = $execution.id;\nconst store = $getWorkflowStaticData('global');\nconst pendingLead = store[execId]?.pendingLead || {};\nif (store[execId]) delete store[execId].pendingLead;\n\nconst response = $input.first().json;\nconst choices = response?.choices;\nconst text = choices?.[0]?.message?.content?.trim() || '';\n\nif (response?.error || !choices || !Array.isArray(choices) || choices.length === 0 || !text) {\n  return [{ json: { ...pendingLead, _should_update: false } }];\n}\n\nfunction extract(label) {\n  const m = text.match(new RegExp(label + ':\\\\s*(.+)', 'i'));\n  if (!m) return 'N/A';\n  const v = m[1].trim();\n  return /^n\\/a$/i.test(v) || !v ? 'N/A' : v.substring(0, 500);\n}\n\nreturn [{ json: {\n  ...pendingLead,\n  person_name:      extract('PERSON_NAME'),\n  person_title:     extract('PERSON_TITLE'),\n  person_phone:     extract('PERSON_PHONE'),\n  person_email:     extract('PERSON_EMAIL'),\n  person_linkedin:  extract('PERSON_LINKEDIN'),\n  person_instagram: extract('PERSON_INSTAGRAM'),\n  person_twitter:   extract('PERSON_TWITTER'),\n  _should_update: true\n}}];"
      }
    },
