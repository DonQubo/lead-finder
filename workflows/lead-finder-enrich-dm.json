    {
      "id": "enrich-buildtavily",
      "name": "Build Tavily Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2448, 304],
      "parameters": {
        "jsCode": "const execId = $execution.id;\nconst store = $getWorkflowStaticData('global');\nif (!store[execId]) store[execId] = {};\nconst lead = $input.first().json;\nstore[execId].pendingLead = { _rowNumber: lead._rowNumber, place_id: lead.place_id || '', name: lead.name || '' };\nstore[execId].leadInfo = { name: lead.name || '', address: lead.address || '', phone: lead.phone || '', website: lead.website || '' };\nconst location = (lead.address || '').split(',').slice(-2).join(',').trim();\nconst websitePart = lead.website ? ' ' + lead.website.replace(/^https?:\\/\\//, '').replace(/\\/$/, '') : '';\nconst query = (lead.name || '') + ' ' + location + websitePart + ' owner CEO director email LinkedIn phone number';\nreturn [{ json: { tavily_body: { api_key: $env.TAVILY_API_KEY, query: query.trim(), search_depth: 'basic', max_results: 3, include_answer: true, include_raw_content: false } }}];"
      }
    },
