    {
      "id": "enrich-stashbroad",
      "name": "Stash Broad Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2884, 480],
      "parameters": {
        "jsCode": "const execId = $execution.id;\nconst store = $getWorkflowStaticData('global');\nif (!store[execId]) store[execId] = {};\nconst leadInfo = store[execId].leadInfo || {};\nstore[execId].broadResults = $input.first().json;\nlet secondQuery;\nif (leadInfo.website) {\n  const domain = leadInfo.website.replace(/^https?:\\/\\//, '').replace(/\\/.*$/, '');\n  secondQuery = 'site:' + domain + ' owner contact about team phone';\n} else {\n  const location = (leadInfo.address || '').split(',').slice(-2).join(',').trim();\n  secondQuery = '\"' + (leadInfo.name || '') + '\" ' + location + ' owner founder director phone site:linkedin.com OR site:facebook.com';\n}\nreturn [{ json: { tavily_site_body: { api_key: $env.TAVILY_API_KEY, query: secondQuery.trim(), search_depth: 'basic', max_results: 3, include_answer: true, include_raw_content: false }}}];"
      }
    },
    {
      "id": "enrich-calltavily2",
      "name": "Call Tavily Site",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [3104, 480],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "https://api.tavily.com/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
