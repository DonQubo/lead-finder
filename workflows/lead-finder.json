      "id": "node-fetchnextpage",
      "name": "Fetch Next Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1248, 600]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst page = $input.first().json;\n\nif (page.places && page.places.length > 0) {\n  const newPlaces = page.places.map(p => ({\n    place_id: p.id,\n    name: p.displayName?.text || '',\n    address: p.formattedAddress || '',\n    phone: p.nationalPhoneNumber || '',\n    website: p.websiteUri || '',\n    business_status: p.businessStatus || '',\n    opening_hours: (p.regularOpeningHours?.weekdayDescriptions || []).join(' | '),\n    price_level: p.priceLevel !== undefined ? String(p.priceLevel) : '',\n    rating: p.rating !== undefined ? String(p.rating) : '',\n    user_ratings_total: p.userRatingCount !== undefined ? String(p.userRatingCount) : '',\n    types: Array.isArray(p.types) ? p.types.filter(t => t !== 'point_of_interest' && t !== 'establishment').join(', ') : ''\n  }));\n  staticData.newPlaces = [...(staticData.newPlaces || []), ...newPlaces];\n  staticData.nextToken = page.nextPageToken || null;\n}\n\nstaticData.pagesRemaining = Math.max(0, (staticData.pagesRemaining || 1) - 1);\n\nif (staticData.newPlaces.length > staticData.maxResults) {\n  staticData.newPlaces = staticData.newPlaces.slice(0, staticData.maxResults);\n}\n\nconst hasMore = !!staticData.nextToken && staticData.pagesRemaining > 0;\n\nreturn [{ json: { has_more: hasMore, place_count: staticData.newPlaces.length, next_page_token: staticData.nextToken, text_query: staticData.textQuery } }];"
      },
      "id": "node-accumulatepage",
      "name": "Accumulate Page",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1472, 600]
    },
    {
      "parameters": {
        "documentId": { "__rl": true, "value": "={{ $('Webhook').first().json.body.sheet_id || 'YOUR_DEFAULT_SHEET_ID' }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Sheet1", "mode": "name" },
        "options": {}
      },
      "id": "node-readsheets",
      "name": "Read Existing Leads",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [1136, 432],
      "alwaysOutputData": true,
      "credentials": { "googleSheetsOAuth2Api": { "id": "YOUR_CREDENTIAL_ID", "name": "Google Sheets account" } }
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst newPlaces = staticData.newPlaces || [];\n\nconst existingIds = new Set(\n  $input.all()\n    .map(item => item.json.place_id)\n    .filter(Boolean)\n);\n\nconst toProcess = newPlaces.filter(p => !existingIds.has(p.place_id));\n\nif (toProcess.length === 0) {\n  return [{ json: { __skip: true } }];\n}\n\nreturn toProcess.map(p => ({ json: p }));"
      },
      "id": "node-deduplicate",
      "name": "Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 432]
    },
