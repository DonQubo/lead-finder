    {
      "parameters": { "options": {} },
      "id": "node-splitbatches",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1808, 312]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.results) staticData.results = [];\n\nconst lead = { ...$input.first().json, found_at: new Date().toISOString() };\n\nstaticData.results.push(lead);\nreturn [{ json: lead }];"
      },
      "id": "node-formatlead",
      "name": "Format Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2032, 144]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst leads = staticData.results || [];\n\nstaticData.results = [];\nstaticData.newPlaces = [];\n\nreturn [{ json: { leads, count: leads.length } }];"
      },
      "id": "node-compileresults",
      "name": "Compile Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2032, 336],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.first().json.leads || [];\nconst sheetId = $('Webhook').first().json.body.sheet_id || 'YOUR_DEFAULT_SHEET_ID';\nconst columns = ['place_id', 'name', 'address', 'phone', 'website', 'business_status', 'opening_hours', 'price_level', 'rating', 'user_ratings_total', 'types', 'found_at'];\nconst values = leads.map(lead => columns.map(col => String(lead[col] != null ? lead[col] : '')));\nreturn [{ json: { values, sheet_id: sheetId } }];"
      },
      "id": "node-preparebatch",
      "name": "Prepare Batch Write",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2256, 336]
    },
    {
      "parameters": {
