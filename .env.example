# n8n webhook for the main lead finder workflow (full URL including path)
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/lead-finder

# Base URL for derived n8n webhooks (no trailing slash, no path)
# Used by /api/leads to call lead-finder-read and lead-finder-dm-data
N8N_WEBHOOK_URL_BASE=https://your-n8n-host/webhook

# Default Google Sheet ID (the long string from the Sheets URL)
LEAD_FINDER_SHEET_ID=your_sheet_id_here

# Secret header value for the enrich-dm webhook (set in n8n credential: "Enrich DM Secret")
ENRICH_DM_SECRET=your_secret_here
